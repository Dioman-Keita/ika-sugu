# Connect to Supabase via connection pooling
# Tip: Supabase pooler typically uses port 6543 (not 5432).
DATABASE_URL="postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres"

# Environment
NODE_ENV="development"

# Supabase (storage + client)
NEXT_PUBLIC_SUPABASE_URL="https://<project_ref>.supabase.co"
# Supabase public publishable key (used client-side for uploads).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_xxx"
# Required for server-side storage delete operations
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_xxx"

# Admin access (comma-separated list of emails) — server-side only
ADMIN_EMAILS=""


# Optional: Supabase DB CA certificate (PEM). If not set, system CAs are used.
SUPABASE_CA_CERT=""

# Escape hatch for local dev only (do NOT use in production)
ALLOW_INSECURE_DB_SSL="false"

# Better Auth
# In production, set a strong secret. Example generation:
# openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me"

# Optional (used for links in emails/oauth if auto-detection isn't enough)
BETTER_AUTH_URL="http://localhost:3000"

# Optional social login (Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email provider (Resend) for password reset emails
RESEND_API_KEY=""
# Must be a valid email format. You can also use: `IKA SUGU <no-reply@example.com>`
RESEND_FROM_EMAIL="no-reply@example.com"

# Currency settings
# API key used to sync exchange rates from the configured provider.
CURRENCY_API_KEY=""
# Global site settings row id used by the admin currency settings feature.
SITE_SETTINGS_ID="global"
# Exchange rate refresh window in milliseconds (default: 6 hours).
EXCHANGE_RATES_REFRESH_WINDOW_MS="21600000"

# Cookie Names (Configurations)
NEXT_PUBLIC_GUEST_CART_COOKIE_NAME="guest_cart_id"
NEXT_PUBLIC_LOCALE_COOKIE_NAME="ui-locale"
NEXT_PUBLIC_THEME_COOKIE_NAME="ui-theme"

# Supabase bucket names
NEXT_PUBLIC_SUPABASE_BUCKET=products

# Stripe Payments
# Found in Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Found by running 'stripe listen' in your terminal for local development
STRIPE_WEBHOOK_SECRET="whsec_..."
